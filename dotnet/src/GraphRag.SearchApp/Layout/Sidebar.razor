@inject AppStateViewModel AppState

<div class="px-4 pt-4">
    <MudText Typo="Typo.subtitle2" Class="mb-3" Style="font-weight: 600;">Options</MudText>

    <MudSelect T="string"
               Value="@AppState.DatasetKey"
               ValueChanged="OnDatasetChanged"
               Label="Dataset"
               Variant="Variant.Outlined"
               Dense="true"
               Class="mb-4">
        @foreach (var ds in AppState.Datasets)
        {
            <MudSelectItem Value="@ds.Key">@ds.Name</MudSelectItem>
        }
    </MudSelect>

    <MudNumericField @bind-Value="AppState.SuggestedQuestionsCount"
                     Label="Number of suggested questions"
                     Variant="Variant.Outlined"
                     Min="1" Max="100" Step="1"
                     Class="mb-4" />

    <MudDivider Class="my-2" />

    <MudText Typo="Typo.subtitle2" Class="mb-2" Style="font-weight: 600;">Search options:</MudText>
    <MudSwitch @bind-Value="AppState.IncludeBasicRag" Label="Include basic RAG" Color="Color.Primary" />
    <MudSwitch @bind-Value="AppState.IncludeLocalSearch" Label="Include local search" Color="Color.Primary" />
    <MudSwitch @bind-Value="AppState.IncludeGlobalSearch" Label="Include global search" Color="Color.Primary" />
    <MudSwitch @bind-Value="AppState.IncludeDriftSearch" Label="Include drift search" Color="Color.Primary" />
</div>

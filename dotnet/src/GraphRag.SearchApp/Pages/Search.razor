@page "/"
@page "/search"
@inject AppStateViewModel AppState
@inject SearchViewModel SearchVm
@inject CommunityExplorerViewModel ExplorerVm
@inject SearchOrchestrator Orchestrator
@inject MarkdownRenderer Renderer
@inject DatasetLoader Loader
@inject KnowledgeModelService ModelService

<PageTitle>GraphRAG Search</PageTitle>

@* ── Page layout: sidebar + main ── matches Python st.sidebar + main content *@
<div class="st-app">
    <aside class="st-sidebar" data-testid="stSidebar">
        <Sidebar />
    </aside>

    <section class="st-main">
        @* ── Heading block ── matches Python home_page.py lines 26-30 *@
        <h4>GraphRAG: A Novel Knowledge Graph-based Approach to Retrieval Augmented Generation (RAG)</h4>
        @if (AppState.DatasetConfig is not null)
        {
            <h5>Dataset selected: @AppState.DatasetConfig.Name</h5>
            <p>@AppState.DatasetConfig.Description</p>
        }

        @* ── Suggest questions button ── matches Python st.button("Suggest some questions") *@
        <div style="margin-bottom: 12px;">
            <button class="st-button st-button--primary" @onclick="SuggestQuestions" disabled="@_isSuggesting">
                @if (_isSuggesting)
                {
                    <span>Generating…</span>
                }
                else
                {
                    <span>Suggest some questions</span>
                }
            </button>
        </div>

        @* ── Text input ── matches Python st.text_input("Ask a question...") *@
        <div style="margin-bottom: 12px;">
            <label class="st-label" for="question-input">Ask a question to compare the results</label>
            <input id="question-input"
                   type="text"
                   class="st-text-input"
                   value="@AppState.Question"
                   @oninput="OnQuestionInput"
                   @onkeyup="OnSearchKeyUp" />
        </div>

        @* ── Generated questions list ── matches Python create_questions_list_ui() st.dataframe *@
        @if (AppState.GeneratedQuestions.Count > 0)
        {
            <div class="st-dataframe-container" style="margin-bottom: 12px;">
                <table class="st-dataframe">
                    <thead><tr><th>question</th></tr></thead>
                    <tbody>
                        @foreach (var q in AppState.GeneratedQuestions)
                        {
                            <tr class="st-dataframe-row" @onclick="() => OnQuestionSelected(q)">
                                <td>@q</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div style="margin-bottom: 12px;">
                <button class="st-button" @onclick="ResetQuestions">Reset</button>
            </div>
        }

        @* ── Tab bar ── matches Python TabBar(tabs=["Search","Community Explorer"]) *@
        <div class="st-tabs" role="tablist">
            <button role="tab"
                    class="st-tab @(_activeTab == 0 ? "st-tab--active" : "")"
                    aria-selected="@(_activeTab == 0)"
                    @onclick='() => SetActiveTab(0)'>Search</button>
            <button role="tab"
                    class="st-tab @(_activeTab == 1 ? "st-tab--active" : "")"
                    aria-selected="@(_activeTab == 1)"
                    @onclick='() => SetActiveTab(1)'>Community Explorer</button>
        </div>

        @* ════════════════════  TAB 0 — Search  ════════════════════ *@
        @if (_activeTab == 0)
        {
            @if (!string.IsNullOrWhiteSpace(AppState.Question))
            {
                <h5>Answering the question: <em>@AppState.Question</em></h5>
            }

            @* Error *@
            @if (!string.IsNullOrEmpty(SearchVm.SearchError))
            {
                <div class="st-alert st-alert--error">@SearchVm.SearchError</div>
            }

            @* Loading spinners *@
            @if (SearchVm.IsSearching)
            {
                <div style="margin-bottom: 12px;">
                    @foreach (var st in _activeSearchTypes)
                    {
                        <p>⏳ Generating answer using @GetSearchTypeLabel(st)...</p>
                    }
                </div>
            }

            @* Results columns — matches Python st.columns(count) *@
            @if (SearchVm.Results.Count > 0)
            {
                <div class="st-columns" style="--col-count: @SearchVm.Results.Count;">
                    @foreach (var result in SearchVm.Results)
                    {
                        <div class="st-column">
                            <SearchResultPanel Result="result" />
                        </div>
                    }
                </div>
            }
            else if (!SearchVm.IsSearching && GetEnabledCount() == 0)
            {
                <p>Please select at least one search option from the sidebar.</p>
            }
        }

        @* ════════════════════  TAB 1 — Community Explorer  ════════════════════ *@
        @if (_activeTab == 1)
        {
            @* matches Python st.columns([0.33, 0.67]) *@
            <div class="st-columns" style="--col-count: 3;">
                <div class="st-column">
                    <h5>Community Reports</h5>

                    @if (ExplorerVm.Reports.Count > 0)
                    {
                        <div class="st-dataframe-container" style="height: 1000px; overflow-y: auto;">
                            <table class="st-dataframe">
                                <thead>
                                    <tr>
                                        <th>human_readable_id</th>
                                        <th>title</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var report in ExplorerVm.Reports)
                                    {
                                        <tr class="st-dataframe-row @(report == ExplorerVm.SelectedReport ? "st-row--selected" : "")"
                                            @onclick="() => OnReportSelected(report)">
                                            <td>@(report.ShortId ?? report.CommunityId)</td>
                                            <td>@report.Title</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p>No community reports loaded. Select a dataset from the sidebar.</p>
                    }
                </div>

                <div class="st-column" style="flex: 2;">
                    <h5>Selected Report</h5>
                    @if (ExplorerVm.SelectedReport is not null)
                    {
                        <ReportDetails Report="ExplorerVm.SelectedReport" />
                    }
                    else
                    {
                        <p>No report selected</p>
                    }
                </div>
            </div>
        }
    </section>
</div>

@page "/"
@page "/search"
@inject AppStateViewModel AppState
@inject SearchViewModel SearchVm
@inject SearchOrchestrator Orchestrator
@inject MarkdownRenderer Renderer

<PageTitle>Search - GraphRAG</PageTitle>

<MudGrid>
    <MudItem xs="12">
        <MudPaper Class="pa-4 mb-4" Elevation="1">
            <MudGrid>
                <MudItem xs="10">
                    <MudTextField @bind-Value="AppState.Question"
                                  Label="Ask a question"
                                  Variant="Variant.Outlined"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  OnKeyUp="OnSearchKeyUp" />
                </MudItem>
                <MudItem xs="2" Class="d-flex align-center">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               OnClick="ExecuteSearch"
                               Disabled="@(SearchVm.IsSearching || string.IsNullOrWhiteSpace(AppState.Question))"
                               FullWidth="true">
                        @if (SearchVm.IsSearching)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        }
                        Search
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudItem>

    @if (AppState.GeneratedQuestions.Count > 0)
    {
        <MudItem xs="12">
            <QuestionsList Questions="AppState.GeneratedQuestions"
                           OnQuestionClicked="OnQuestionSelected" />
        </MudItem>
    }

    @if (!string.IsNullOrEmpty(SearchVm.SearchError))
    {
        <MudItem xs="12">
            <MudAlert Severity="Severity.Error" Class="mb-4">@SearchVm.SearchError</MudAlert>
        </MudItem>
    }

    @if (SearchVm.IsSearching)
    {
        <MudItem xs="12">
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
        </MudItem>
    }

    @foreach (var result in SearchVm.Results)
    {
        <MudItem xs="12" md="@GetColumnWidth()">
            <SearchResultPanel Result="result" />
        </MudItem>
    }
</MudGrid>

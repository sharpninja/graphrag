@* Questions list — matches Python create_questions_list_ui() st.dataframe *@
<div class="st-dataframe-container" style="margin-bottom: 12px;">
    <table class="st-dataframe">
        <thead><tr><th>question</th></tr></thead>
        <tbody>
            @foreach (var question in Questions)
            {
                <tr class="st-dataframe-row" @onclick="() => OnQuestionClicked.InvokeAsync(question)">
                    <td>@question</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    /// <summary>
    /// Gets or sets the list of generated questions.
    /// </summary>
    [Parameter]
    [EditorRequired]
    public IReadOnlyCollection<string> Questions { get; set; } = [];

    /// <summary>
    /// Gets or sets the callback for when a question is clicked.
    /// </summary>
    [Parameter]
    public EventCallback<string> OnQuestionClicked { get; set; }
}
